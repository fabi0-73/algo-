# Copy to .env and fill in your values.
# cp .env.example .env   (Linux/Mac)  or  copy .env.example .env  (Windows)

# -----------------------------------------------------------------------------
# MetaTrader 5 (live data / execution)
# -----------------------------------------------------------------------------
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# -----------------------------------------------------------------------------
# Database (optional fallback for candle data)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=amd_trading
DB_USER=postgres
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Timezone (broker server time)
# -----------------------------------------------------------------------------
DATA_TIMEZONE=UTC
SESSION_TIMEZONE=UTC

# -----------------------------------------------------------------------------
# Telegram (live signal notifications)
# -----------------------------------------------------------------------------
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
